{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/pre-push-trivy.sh",
            "timeout": 600
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import json; print(json.dumps({'hookSpecificOutput': {'hookEventName': 'UserPromptSubmit', 'additionalContext': 'Use harness rules from harness/core/rules.md, harness/core/workflow.md, harness/core/quality-gates.md, and harness/core/openspec-workflows.md. Use the behavior sources configured in harness.yml. {{SPEC_GUIDANCE}} Run ./harness/scripts/verify.sh before finishing.'}}))\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/quality-gates.sh",
            "timeout": 600
          },
          {
            "type": "command",
            "command": ".codex/hooks/tdd-check.sh",
            "timeout": 60
          },
          {
            "type": "command",
            "command": ".codex/hooks/trivy-secrets.sh",
            "timeout": 300
          },
          {
            "type": "command",
            "command": ".codex/hooks/trivy-vuln.sh",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
